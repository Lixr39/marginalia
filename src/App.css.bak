* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
  scrollbar-width: thin;
  scrollbar-color: rgba(255, 255, 255, 0.08) transparent;
}

body {
  background: #0b0b19;
  color: #e8e8f0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Inter", Roboto, sans-serif;
  overflow: hidden;
  -webkit-font-smoothing: antialiased;
}

.app {
  height: 100vh;
  overflow: hidden;
}

/* ===== Scrollbar ===== */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: transparent;
}

::-webkit-scrollbar-thumb {
  background: rgba(255, 255, 255, 0.08);
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: rgba(255, 255, 255, 0.15);
}

#root {
  height: 100vh;
}

/* ===== Home ===== */
.home {
  height: 100vh;
  overflow: hidden;
  background: #06060f;
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 48px 32px;
  position: relative;
}

/* Animated aurora background */
.home::before {
  content: '';
  position: absolute;
  inset: -50%;
  background:
    radial-gradient(ellipse 600px 400px at 30% 20%, rgba(99, 102, 241, 0.15), transparent),
    radial-gradient(ellipse 500px 350px at 70% 70%, rgba(139, 92, 246, 0.12), transparent),
    radial-gradient(ellipse 400px 300px at 50% 50%, rgba(59, 130, 246, 0.08), transparent);
  animation: auroraMove 12s ease-in-out infinite alternate;
  pointer-events: none;
}

.home::after {
  content: '';
  position: absolute;
  inset: -50%;
  background:
    radial-gradient(ellipse 450px 350px at 60% 30%, rgba(168, 85, 247, 0.1), transparent),
    radial-gradient(ellipse 350px 250px at 20% 80%, rgba(79, 70, 229, 0.08), transparent);
  animation: auroraMove2 15s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes auroraMove {
  0% { transform: translate(0, 0) rotate(0deg) scale(1); }
  33% { transform: translate(5%, -3%) rotate(2deg) scale(1.05); }
  66% { transform: translate(-3%, 5%) rotate(-1deg) scale(0.98); }
  100% { transform: translate(2%, -2%) rotate(1deg) scale(1.02); }
}

@keyframes auroraMove2 {
  0% { transform: translate(0, 0) rotate(0deg) scale(1); }
  50% { transform: translate(-4%, 3%) rotate(-2deg) scale(1.08); }
  100% { transform: translate(3%, -4%) rotate(1.5deg) scale(0.95); }
}

/* Subtle noise grain overlay */
.home .home-content::before {
  content: '';
  position: fixed;
  inset: 0;
  opacity: 0.03;
  background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)'/%3E%3C/svg%3E");
  pointer-events: none;
  z-index: 0;
}

.home-content {
  max-width: 820px;
  width: 100%;
  position: relative;
  z-index: 1;
}

.home-title {
  font-size: 54px;
  font-weight: 700;
  font-style: italic;
  color: #fff;
  margin-bottom: 16px;
  letter-spacing: 6px;
  text-align: center;
  font-family: "Spectral SC", "Georgia", serif;
  background: linear-gradient(135deg, #ffffff 0%, #e2d6f5 35%, #b49aec 70%, #8b7bd4 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
  animation: titleGlow 4s ease-in-out infinite alternate;
}

@keyframes titleGlow {
  0% { filter: brightness(1) drop-shadow(0 0 0 transparent); }
  100% { filter: brightness(1.1) drop-shadow(0 0 30px rgba(139, 92, 246, 0.15)); }
}

.home-title-line {
  width: 60px;
  height: 1px;
  margin: 0 auto 20px;
  background: linear-gradient(90deg, transparent, rgba(139, 92, 246, 0.4), transparent);
}

.home-subtitle {
  font-size: 13px;
  color: #4e4e6e;
  margin-bottom: 56px;
  text-align: center;
  letter-spacing: 3px;
  font-weight: 300;
}

/* ===== Home Cards Grid (horizontal) ===== */
.home-cards {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.home-card {
  background: rgba(18, 18, 42, 0.5);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  padding: 36px 24px 32px;
  cursor: pointer;
  transition: all 0.3s ease;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 16px;
  position: relative;
  overflow: hidden;
  min-height: 220px;
}

.home-card::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 16px;
  padding: 1px;
  background: linear-gradient(135deg, rgba(99, 102, 241, 0), rgba(139, 92, 246, 0));
  -webkit-mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
  -webkit-mask-composite: xor;
  mask-composite: exclude;
  transition: background 0.3s;
}

.home-card:hover {
  transform: translateY(-6px);
  background: rgba(26, 26, 52, 0.85);
  box-shadow: 0 16px 48px rgba(99, 102, 241, 0.12), 0 0 0 1px rgba(139, 92, 246, 0.1);
}

.home-card:hover::before {
  background: linear-gradient(135deg, rgba(99, 102, 241, 0.4), rgba(139, 92, 246, 0.2));
}

.home-card-icon {
  width: 60px;
  height: 60px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28px;
  flex-shrink: 0;
}

.home-card-icon.api {
  background: linear-gradient(135deg, rgba(34, 197, 94, 0.15), rgba(16, 185, 129, 0.08));
  color: #4ade80;
}

.home-card-icon.chars {
  background: linear-gradient(135deg, rgba(139, 92, 246, 0.15), rgba(99, 102, 241, 0.08));
  color: #a78bfa;
}

.home-card-icon.books {
  background: linear-gradient(135deg, rgba(251, 191, 36, 0.15), rgba(245, 158, 11, 0.08));
  color: #fbbf24;
}

.home-card-title {
  font-size: 17px;
  font-weight: 600;
  color: #f0f0f5;
  letter-spacing: 0.5px;
}

.home-card-desc {
  font-size: 13px;
  color: #6b6b8d;
  line-height: 1.6;
}

.home-card-status {
  font-size: 11px;
  padding: 3px 12px;
  border-radius: 20px;
  font-weight: 500;
}

.home-card-status.done {
  color: #4ade80;
  background: rgba(74, 222, 128, 0.1);
  border: 1px solid rgba(74, 222, 128, 0.15);
}

.home-card-status.pending {
  color: #fb923c;
  background: rgba(251, 146, 60, 0.1);
  border: 1px solid rgba(251, 146, 60, 0.15);
}

.home-card-action {
  font-size: 12px;
  color: #8b8baa;
  margin-top: auto;
  padding-top: 4px;
  transition: color 0.2s;
}

.home-card:hover .home-card-action {
  color: #a78bfa;
}

/* ===== Character Gallery Overlay ===== */
.char-gallery-overlay {
  position: fixed;
  inset: 0;
  background: rgba(5, 5, 15, 0.8);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 900;
  animation: fadeIn 0.2s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.char-gallery {
  background: rgba(18, 18, 36, 0.95);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  padding: 32px;
  max-width: 580px;
  width: 90vw;
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.25s ease;
}

@keyframes slideUp {
  from { transform: translateY(20px); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.char-gallery-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24px;
}

.char-gallery-header h2 {
  font-size: 20px;
  font-weight: 700;
  color: #fff;
}

.char-gallery-close {
  background: none;
  border: none;
  color: #666;
  font-size: 20px;
  cursor: pointer;
  padding: 4px 8px;
  border-radius: 6px;
  transition: all 0.15s;
}

.char-gallery-close:hover {
  color: #ccc;
  background: rgba(255, 255, 255, 0.05);
}

.char-gallery-hint {
  font-size: 12px;
  color: #6b6b8d;
  margin-bottom: 20px;
  line-height: 1.5;
}

.char-gallery-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.char-gallery-item {
  display: flex;
  align-items: flex-start;
  gap: 14px;
  padding: 16px;
  border-radius: 12px;
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.04);
  transition: all 0.2s;
}

.char-gallery-item:hover {
  background: rgba(255, 255, 255, 0.06);
  border-color: rgba(139, 92, 246, 0.15);
}

.char-gallery-avatar {
  font-size: 28px;
  flex-shrink: 0;
  width: 44px;
  height: 44px;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.04);
  border-radius: 12px;
}

.char-gallery-info {
  flex: 1;
  min-width: 0;
}

.char-gallery-name {
  font-size: 15px;
  font-weight: 600;
  color: #f0f0f5;
  margin-bottom: 2px;
}

.char-gallery-label {
  font-size: 11px;
  color: #a78bfa;
  background: rgba(139, 92, 246, 0.12);
  padding: 2px 8px;
  border-radius: 6px;
  display: inline-block;
  margin-bottom: 6px;
}

.char-gallery-desc {
  font-size: 13px;
  color: #8888aa;
  line-height: 1.6;
}

/* ===== Reading Layout ===== */
.reading-layout {
  height: 100vh;
  display: flex;
  flex-direction: column;
}

.reading-layout {
  background: var(--t-bg, #0b0b19);
  color: var(--t-color, #e0e0e0);
  animation: viewFadeIn 0.3s ease;
}

@keyframes viewFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.reading-header {
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 10px 16px;
  background: var(--t-header, rgba(11, 11, 25, 0.95));
  border-bottom: 1px solid var(--t-border, rgba(255, 255, 255, 0.06));
  flex-shrink: 0;
  position: relative;
  backdrop-filter: blur(12px);
}

.header-group-left,
.header-group-right {
  display: flex;
  align-items: center;
  gap: 4px;
  flex-shrink: 0;
}

.header-nav-group {
  display: flex;
  gap: 1px;
  background: var(--t-border, rgba(255,255,255,0.06));
  border-radius: 8px;
  overflow: hidden;
}

.header-nav-group .nav-btn {
  border-radius: 0;
  border: none;
  padding: 6px 10px;
  font-size: 10px;
}

.back-btn,
.header-btn {
  background: var(--t-surface, rgba(255, 255, 255, 0.04));
  border: 1px solid var(--t-border, rgba(255, 255, 255, 0.08));
  color: var(--t-muted, #aaa);
  font-size: 13px;
  cursor: pointer;
  padding: 6px 12px;
  border-radius: 8px;
  white-space: nowrap;
  flex-shrink: 0;
  transition: all 0.15s ease;
}

.back-btn:hover,
.header-btn:hover {
  border-color: rgba(139, 92, 246, 0.4);
  color: #c4b5fd;
  background: rgba(139, 92, 246, 0.08);
}

.reading-title {
  flex: 1;
  text-align: center;
  font-size: 13px;
  color: var(--t-muted, #7777aa);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.toc-panel {
  position: absolute;
  top: 44px;
  left: 0;
  width: 300px;
  max-height: calc(100vh - 60px);
  overflow-y: auto;
  background: var(--t-header, rgba(18, 18, 36, 0.98));
  border: 1px solid var(--t-border, rgba(255, 255, 255, 0.06));
  border-radius: 0 0 14px 0;
  padding: 16px;
  z-index: 200;
  backdrop-filter: blur(16px);
  box-shadow: 4px 4px 24px rgba(0, 0, 0, 0.4);
}

.toc-panel h3 {
  margin: 0 0 12px;
  font-size: 14px;
  font-weight: 600;
  color: #e0e0f0;
}

.toc-item {
  padding: 8px 12px;
  font-size: 13px;
  color: var(--t-muted, #8888aa);
  cursor: pointer;
  border-radius: 8px;
  transition: all 0.15s;
}

.toc-item:hover {
  background: rgba(139, 92, 246, 0.08);
  color: #c4b5fd;
}

.reading-body {
  flex: 1;
  display: flex;
  overflow: hidden;
  min-height: 0;
}

/* ===== Pre-read Panel ===== */
.preread-btn.has-data {
  border-color: rgba(74, 222, 128, 0.4);
  color: #4ade80;
  background: rgba(74, 222, 128, 0.06);
}

.preread-panel {
  position: absolute;
  top: 44px;
  right: 380px;
  width: 360px;
  max-height: calc(100vh - 60px);
  overflow-y: auto;
  background: var(--t-header, rgba(18, 18, 36, 0.98));
  border: 1px solid var(--t-border, rgba(255, 255, 255, 0.06));
  border-radius: 0 0 0 14px;
  padding: 16px;
  z-index: 200;
  backdrop-filter: blur(16px);
  box-shadow: -4px 4px 24px rgba(0, 0, 0, 0.4);
}

.preread-panel h3 {
  margin: 0 0 8px;
  font-size: 14px;
  font-weight: 600;
  color: #e0e0f0;
}

.preread-desc {
  font-size: 12px;
  color: #7777aa;
  line-height: 1.6;
  margin-bottom: 12px;
}

.preread-actions {
  display: flex;
  gap: 8px;
  margin-bottom: 12px;
}

.preread-action-btn {
  flex: 1;
  padding: 8px;
  border: 1px solid rgba(139, 92, 246, 0.3);
  border-radius: 8px;
  background: rgba(139, 92, 246, 0.06);
  color: #a78bfa;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.15s;
}

.preread-action-btn:hover:not(:disabled) {
  background: rgba(139, 92, 246, 0.12);
  border-color: rgba(139, 92, 246, 0.5);
}

.preread-action-btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
}

.preread-progress {
  padding: 8px 12px;
  background: rgba(139, 92, 246, 0.08);
  border: 1px solid rgba(139, 92, 246, 0.1);
  border-radius: 8px;
  font-size: 12px;
  color: #aaa;
  margin-bottom: 12px;
}

.preread-list {
  border-top: 1px solid rgba(255, 255, 255, 0.06);
  padding-top: 12px;
}

.preread-list h4 {
  font-size: 12px;
  color: #7777aa;
  margin: 0 0 8px;
  font-weight: 500;
}

.preread-item {
  padding: 6px 0;
  font-size: 12px;
  color: #6b6b8d;
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
}

/* ===== Selection Action Bar ===== */
.selection-bar {
  background: var(--t-header, rgba(18, 18, 36, 0.95));
  border-bottom: 1px solid var(--t-border, rgba(255, 255, 255, 0.06));
  padding: 10px 16px;
  flex-shrink: 0;
  animation: slideDown 0.15s ease-out;
  backdrop-filter: blur(12px);
}

@keyframes slideDown {
  from { transform: translateY(-100%); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

.selection-bar-text {
  font-size: 13px;
  color: #8888aa;
  font-style: italic;
  margin-bottom: 8px;
  line-height: 1.5;
  max-height: 40px;
  overflow: hidden;
}

.selection-bar-actions {
  display: flex;
  gap: 8px;
}

.sel-action-btn {
  padding: 6px 16px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  background: transparent;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.15s;
}

.sel-action-btn.sel-read {
  color: #818cf8;
  border-color: rgba(129, 140, 248, 0.3);
}
.sel-action-btn.sel-read:hover {
  background: rgba(129, 140, 248, 0.1);
  border-color: rgba(129, 140, 248, 0.5);
}

.sel-action-btn.sel-highlight {
  color: #fbbf24;
  border-color: rgba(251, 191, 36, 0.3);
}
.sel-action-btn.sel-highlight:hover {
  background: rgba(251, 191, 36, 0.08);
  border-color: rgba(251, 191, 36, 0.5);
}

.sel-action-btn.sel-annotate {
  color: #c084fc;
  border-color: rgba(192, 132, 252, 0.3);
}
.sel-action-btn.sel-annotate:hover {
  background: rgba(192, 132, 252, 0.08);
  border-color: rgba(192, 132, 252, 0.5);
}

.sel-action-btn.sel-dismiss {
  color: #555;
  border-color: transparent;
  padding: 6px 10px;
}
.sel-action-btn.sel-dismiss:hover {
  color: #888;
}

.annotation-input-row {
  display: flex;
  gap: 8px;
  margin-top: 8px;
}

.annotation-input-row input {
  flex: 1;
  padding: 8px 12px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  background: rgba(11, 11, 25, 0.8);
  color: #e0e0f0;
  font-size: 13px;
  outline: none;
  transition: border-color 0.2s;
}

.annotation-input-row input:focus {
  border-color: rgba(192, 132, 252, 0.5);
}

.annotation-input-row button {
  padding: 8px 14px;
  border: none;
  border-radius: 8px;
  background: linear-gradient(135deg, #7c3aed, #6366f1);
  color: white;
  font-size: 13px;
  cursor: pointer;
  transition: opacity 0.2s;
}

.annotation-input-row button:hover {
  opacity: 0.9;
}

/* ===== Dialog Overlay ===== */
.dialog-overlay {
  position: fixed;
  inset: 0;
  background: rgba(5, 5, 15, 0.75);
  backdrop-filter: blur(6px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
}

.dialog-box {
  background: rgba(22, 22, 42, 0.98);
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 16px;
  padding: 28px;
  max-width: 380px;
  text-align: center;
  box-shadow: 0 16px 48px rgba(0, 0, 0, 0.5);
}

.dialog-box h3 {
  color: #f0f0f5;
  font-size: 17px;
  font-weight: 600;
  margin: 0 0 8px;
}

.dialog-box p {
  color: #8888aa;
  font-size: 13px;
  line-height: 1.6;
  margin: 0 0 24px;
}

.dialog-actions {
  display: flex;
  gap: 12px;
  justify-content: center;
}

.dialog-cancel {
  padding: 8px 20px;
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 8px;
  background: transparent;
  color: #aaa;
  font-size: 13px;
  cursor: pointer;
  transition: all 0.15s;
}

.dialog-cancel:hover { border-color: rgba(255, 255, 255, 0.2); color: #ccc; }

.dialog-confirm {
  padding: 8px 20px;
  border: none;
  border-radius: 8px;
  background: linear-gradient(135deg, #6366f1, #7c3aed);
  color: #fff;
  font-size: 13px;
  cursor: pointer;
  transition: opacity 0.2s;
}

.dialog-confirm:hover { opacity: 0.9; }

/* ===== Theme Picker ===== */
.theme-picker-panel {
  position: absolute;
  top: 44px;
  right: 200px;
  width: 300px;
  background: var(--t-header, rgba(18, 18, 36, 0.98));
  border: 1px solid var(--t-border, rgba(255, 255, 255, 0.06));
  border-radius: 12px;
  padding: 16px;
  z-index: 200;
  backdrop-filter: blur(16px);
  box-shadow: 0 8px 32px rgba(0, 0, 0, 0.4);
}

.theme-picker-section {
  margin-bottom: 14px;
}

.theme-picker-section:last-child {
  margin-bottom: 0;
}

.theme-picker-label {
  font-size: 11px;
  color: #7777aa;
  margin-bottom: 8px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.theme-picker-row {
  display: flex;
  gap: 6px;
}

.theme-swatch-wrap {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6px;
  cursor: pointer;
  padding: 4px;
  border-radius: 8px;
  transition: background 0.15s;
}

.theme-swatch-wrap:hover {
  background: var(--t-hover, rgba(255,255,255,0.04));
}

.theme-swatch-circle {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.15);
  transition: all 0.15s;
}

.theme-swatch-wrap.active .theme-swatch-circle {
  border-color: #6366f1 !important;
  box-shadow: 0 0 10px rgba(99, 102, 241, 0.35);
}

.theme-swatch-name {
  font-size: 10px;
  color: var(--t-muted, #7777aa);
}

.theme-font-btn {
  flex: 1;
  padding: 8px 4px;
  border: 1px solid rgba(255, 255, 255, 0.08);
  border-radius: 8px;
  background: rgba(255, 255, 255, 0.03);
  color: #aaa;
  font-size: 12px;
  cursor: pointer;
  transition: all 0.15s;
}

.theme-font-btn.active {
  border-color: rgba(99, 102, 241, 0.5);
  color: #c4b5fd;
  background: rgba(99, 102, 241, 0.08);
}

.theme-font-btn:hover:not(.active) {
  border-color: rgba(255, 255, 255, 0.15);
  color: #ccc;
}

/* ===== Font Size Control ===== */
.font-size-control {
  display: flex;
  align-items: center;
  gap: 8px;
}

.font-size-btn {
  width: 32px;
  height: 32px;
  border-radius: 8px;
  border: 1px solid var(--t-border, rgba(255,255,255,0.1));
  background: var(--t-surface, rgba(255,255,255,0.04));
  color: var(--t-color, #ccc);
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.15s;
  display: flex;
  align-items: center;
  justify-content: center;
}

.font-size-btn:hover {
  border-color: rgba(139, 92, 246, 0.4);
  color: #c4b5fd;
}

.font-size-value {
  font-size: 12px;
  color: var(--t-color, #ccc);
  min-width: 36px;
  text-align: center;
  font-variant-numeric: tabular-nums;
}

.font-size-slider {
  flex: 1;
  height: 4px;
  -webkit-appearance: none;
  appearance: none;
  background: var(--t-border, rgba(255,255,255,0.1));
  border-radius: 2px;
  outline: none;
  cursor: pointer;
}

.font-size-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  width: 14px;
  height: 14px;
  border-radius: 50%;
  background: #6366f1;
  cursor: pointer;
  transition: box-shadow 0.15s;
}

.font-size-slider::-webkit-slider-thumb:hover {
  box-shadow: 0 0 8px rgba(99, 102, 241, 0.4);
}

/* ===== History Dialog ===== */
.history-dialog {
  background: rgba(18, 18, 36, 0.98);
  border: 1px solid rgba(255, 255, 255, 0.06);
  border-radius: 20px;
  padding: 28px;
  max-width: 560px;
  width: 90vw;
  max-height: 80vh;
  overflow-y: auto;
  animation: slideUp 0.25s ease;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20px;
}

.history-header h3 {
  font-size: 18px;
  font-weight: 700;
  color: #fff;
}

.history-empty {
  text-align: center;
  color: #7777aa;
  font-size: 14px;
  padding: 32px 0;
  line-height: 1.6;
}

.history-list {
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.history-item {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(255, 255, 255, 0.05);
  border-radius: 12px;
  padding: 14px;
}

.history-item-header {
  display: flex;
  align-items: center;
  gap: 8px;
  margin-bottom: 6px;
}

.history-char-name {
  font-size: 15px;
  font-weight: 600;
  color: #f0f0f5;
}

.history-mode {
  font-size: 10px;
  color: #a78bfa;
  background: rgba(139, 92, 246, 0.1);
  padding: 2px 8px;
  border-radius: 8px;
}

.history-time {
  font-size: 11px;
  color: #6b6b8d;
  margin-left: auto;
}

.history-stats {
  font-size: 12px;
  color: #7777aa;
  margin-bottom: 8px;
}

.history-preview {
  font-size: 12px;
  color: #8888aa;
  line-height: 1.5;
  padding: 6px 10px;
  background: rgba(255, 255, 255, 0.02);
  border-radius: 6px;
  margin-top: 4px;
}

.history-item:hover {
  border-color: rgba(139, 92, 246, 0.3);
  background: rgba(139, 92, 246, 0.04);
}

.history-action-hint {
  font-size: 11px;
  color: #6366f1;
  margin-top: 8px;
  opacity: 0;
  transition: opacity 0.15s;
}

.history-item:hover .history-action-hint {
  opacity: 1;
}

/* ===== Reading mode tag (label only) ===== */
.reading-mode-tag {
  font-size: 11px;
  color: var(--t-muted, #a78bfa);
  background: rgba(139, 92, 246, 0.1);
  border: 1px solid rgba(139, 92, 246, 0.15);
  padding: 3px 10px;
  border-radius: 20px;
  white-space: nowrap;
  flex-shrink: 0;
  cursor: help;
}
